{
    "name": "three-types-modded",
    "version": "0.168.10003",
    "projects": [
        "https://threejs.org/"
    ],
    "types": "./index.d.ts",
    "type": "module",
    "files": [
        "build",
        "examples",
        "src",
        "index.d.ts"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/repalash/three-ts-types"
    },
    "license": "MIT",
    "exports": {
        ".": {
            "import": "./build/three.module.js",
            "require": "./build/three.cjs"
        },
        "./examples/fonts/*": "./examples/fonts/*",
        "./examples/jsm/*": "./examples/jsm/*",
        "./addons": "./examples/jsm/Addons.js",
        "./addons/*": "./examples/jsm/*",
        "./src/*": "./src/*",
        "./webgpu": "./build/three.webgpu.js",
        "./tsl": "./build/three.webgpu.js"
    },
    "scripts": {
        "release": "git diff --exit-code && git tag publish@$npm_package_version && git push origin publish@$npm_package_version"
    },
    "dependencies": {
        "@tweenjs/tween.js": "~23.1.3",
        "@types/stats.js": "*",
        "@types/webxr": "*",
        "@webgpu/types": "*",
        "meshoptimizer": "~0.18.1"
    },
    "owners": [
        {
            "name": "Josh Ellis",
            "githubUsername": "joshuaellis"
        },
        {
            "name": "Nathan Bierema",
            "githubUsername": "Methuselah96"
        }
    ]
}
